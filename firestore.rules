rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Anonymous devices collection rules - secure tracking of guest device limits.
    // Kept because the app uses device-scoped rate limiting without authentication.
    match /anonymous_devices/{deviceId} {
      // Access requires knowing the specific generated deviceId
      allow read: if true;
      allow create: if request.resource.data.scansLeft <= 3;
      allow update: if (
                      // Only allow decreasing or keeping the scansLeft count (prevent bypass)
                      (!('scansLeft' in request.resource.data)) ||
                      (!('scansLeft' in resource.data) && request.resource.data.scansLeft <= 3) ||
                      (request.resource.data.scansLeft <= resource.data.scansLeft)
                    );
      allow delete: if false; // Guests cannot delete tracking records
    }

    // ═════════════════════════════════════════════════════════════════════════
    // Scientific Collections — Public Read-Only, No Authentication Required.
    // The App Store approved build runs without any user accounts; these
    // collections are the scientific backbone downloaded and cached locally.
    // ═════════════════════════════════════════════════════════════════════════

    // Reagents collection — reagent definitions and test data
    match /reagents/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Reagent groups — categorization of reagents
    match /reagent_groups/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Color profiles — color reference tables for reaction interpretation
    match /color_profiles/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Substances — substance definitions and properties
    match /substances/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Reaction results — expected color reactions for substance/reagent combinations
    match /reaction_results/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Scientific references — citations and source information
    match /scientific_references/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Reference images — images for color comparison
    match /reference_images/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Hazard information — safety and hazard data for substances
    match /hazard_information/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Safety notes — handling and safety instructions
    match /safety_notes/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Reagent metadata — version info and dataset metadata
    match /reagent_metadata/{document} {
      allow read: if true;
      allow write: if false;
    }
  }
}
